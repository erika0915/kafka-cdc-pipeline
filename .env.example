# Kafka KRaft Cluster ID (generate with: kafka-storage.sh random-uuid)
CLUSTER_ID=your-cluster-id

# Source MySQL (컨테이너 내부용)
MYSQL_ROOT_PASSWORD=your-root-password
MYSQL_USER=your-app-user
MYSQL_PASSWORD=your-app-password

# Debezium이 binlog 읽을 때 쓰는 계정
MYSQL_SOURCE_HOST=mysql-source
MYSQL_SOURCE_PORT=3306
MYSQL_SOURCE_USER=your-debezium-user
MYSQL_SOURCE_PASSWORD=your-debezium-password

# Sink PostgreSQL
PG_SINK_URL=jdbc:postgresql://postgres-sink:5432/targetdb
PG_SINK_USER=your-pg-user
PG_SINK_PASSWORD=your-pg-password
