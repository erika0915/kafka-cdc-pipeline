{
  "name": "pg-sink",
  "config": {
    "connector.class": "io.confluent.connect.jdbc.JdbcSinkConnector",
    "tasks.max": "1",
    "topics": "cdc.testdb.users",
    "connection.url": "${env:PG_SINK_URL}",
    "connection.user": "${env:PG_SINK_USER}",
    "connection.password": "${env:PG_SINK_PASSWORD}",
    "insert.mode": "upsert",
    "pk.mode": "record_key",
    "pk.fields": "id",
    "auto.create": "true",
    "auto.evolve": "true",
    "delete.enabled": "true",
    "transforms": "route",
    "transforms.route.type": "org.apache.kafka.connect.transforms.RegexRouter",
    "transforms.route.regex": ".*\\..*\\.(.*)",
    "transforms.route.replacement": "$1"
  }
}
